#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
worktree="${NICKOSULLIVAN_GH_PAGES_WORKTREE:-/tmp/nicksweb-gh-pages}"
message="Publish current Jekyll build"

usage() {
  echo "Usage: $0 [-m MESSAGE] [MESSAGE]" >&2
}

if [[ "${1:-}" == "-m" ]]; then
  if [[ -z "${2:-}" || $# -gt 2 ]]; then
    usage
    exit 2
  fi
  message="$2"
elif [[ $# -eq 1 ]]; then
  message="$1"
elif [[ $# -gt 1 ]]; then
  usage
  exit 2
fi

cd "$repo_root"

echo "==> Installing locked Ruby gems if needed"
bundle config set path vendor/bundle >/dev/null
bundle install

echo "==> Building Jekyll site"
JEKYLL_ENV=production bundle exec jekyll build
touch "$repo_root/_site/.nojekyll"

echo "==> Preparing gh-pages worktree"
# A previously interrupted publish can leave a missing worktree registered in
# Git's metadata. Remove or prune that registration before recreating it.
git worktree remove --force "$worktree" 2>/dev/null || true
git worktree prune
if [[ -e "$worktree" ]]; then
  rm -rf -- "$worktree"
fi
if git show-ref --verify --quiet refs/remotes/origin/gh-pages; then
  git worktree add "$worktree" origin/gh-pages
else
  git worktree add --orphan "$worktree"
fi

echo "==> Syncing _site to gh-pages"
rsync -a --delete --exclude .git "$repo_root/_site/" "$worktree/"

cd "$worktree"
git add -A
if git diff --cached --quiet; then
  echo "==> No gh-pages changes to publish"
else
  git commit -m "$message"
  git push origin HEAD:gh-pages
fi

cd "$repo_root"
git worktree remove "$worktree"

echo "==> Done"
